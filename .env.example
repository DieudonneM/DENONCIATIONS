# Local / production configuration
# Copy this file to .env and replace values with your settings.

# Django Configuration
# Generate a strong SECRET_KEY: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-super-secret-key-here

# Local Development Settings
DEBUG=True
USE_SQLITE=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration (used when USE_SQLITE=False)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=denunciations_app
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Production Settings (set these on Render)
# DEBUG=False
# USE_SQLITE=False
# ALLOWED_HOSTS=your-app-name.onrender.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

