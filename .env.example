# Local / production configuration
# Copy this file to .env and replace values with your settings.

# Environment: 'local' or 'production'
ENVIRONMENT=local

SECRET_KEY=change-me-very-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration
# For LOCAL development (SQLite) - set USE_SQLITE=True
USE_SQLITE=True

# For PRODUCTION (PostgreSQL on Render) - set USE_SQLITE=False and configure below
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=127.0.0.1
DB_PORT=5432
